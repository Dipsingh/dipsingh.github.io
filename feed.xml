---
layout: null
permalink: /feed.xml
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title | default: site.name | xml_escape }}</title>
  <link href="{{ site.url | default: "https://dipsingh.github.io" }}{{ site.baseurl }}"/>
  <link href="{{ site.url | default: "https://dipsingh.github.io" }}{{ site.baseurl }}/feed.xml" rel="self" type="application/atom+xml"/>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ site.url | default: "https://dipsingh.github.io" }}{{ site.baseurl }}/</id>

  {% if site.author and site.author.name %}
  <author><name>{{ site.author.name | xml_escape }}</name></author>
  {% endif %}

  {% for post in site.posts limit:20 %}
  <entry>
    <title>{{ post.title | xml_escape }}</title>
    <link href="{{ post.url | absolute_url }}"/>
    <id>{{ post.id | absolute_url }}</id>
    <updated>{{ post.date | date_to_xmlschema }}</updated>

    {%- comment -%}
      Build a short, safe excerpt:
      - Prefer post.excerpt (Jekyll’s first paragraph), else full content
      - Render Markdown to HTML (markdownify)
      - Strip HTML tags so we keep just text
      - Truncate to 120 words to avoid giant code/log blobs
      - XML-escape the result so it’s valid inside Atom <content>
    {%- endcomment -%}
    {% capture raw %}{{ post.excerpt | default: post.content | markdownify }}{% endcapture %}
    {% assign safe = raw | strip_html | truncatewords: 120 | xml_escape %}

    <content type="html">{{ safe }}</content>
  </entry>
  {% endfor %}
</feed>